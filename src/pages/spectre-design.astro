---
import Layout from '../layouts/Layout.astro'
import { SpCard } from '@phcdevworks/spectre-ui-astro'

const packages = [
  {
    name: 'Spectre Tokens',
    detail:
      'The design-token package of the Spectre system for downstream packages and compatible applications.',
  },
  {
    name: 'Spectre UI',
    detail:
      'The implementation layer between Spectre Tokens and downstream adapters or applications.',
  },
  {
    name: 'Spectre UI Astro',
    detail:
      'The Astro adapter package for Astro applications that consume the core Spectre UI contract.',
  },
]
---

<Layout
  title="Spectre Design"
  description="Spectre Design covers Spectre Tokens, Spectre UI, and Spectre UI Astro as the core layers of the Spectre design system."
>
  <section class="page-intro">
    <p class="eyebrow">Spectre Design</p>
    <h1 class="display-headline">The core layers of the Spectre design system.</h1>
    <p class="lead page-lead">
      Spectre Design covers the token package, the UI implementation layer, and
      the Astro adapter.
    </p>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Packages</p>
      <h2 class="section-title">Three layers working from one shared contract.</h2>
    </div>

    <div class="stack-list">
      {
        packages.map((item) => (
          <SpCard as="article" variant="outline" padded>
            <p class="stack-item__kicker">Package</p>
            <h3 class="stack-item__title">{item.name}</h3>
            <p class="stack-item__copy">{item.detail}</p>
          </SpCard>
        ))
      }
    </div>
  </section>

  <section class="section-block section-band">
    <div class="section-heading">
      <p class="eyebrow">Why it matters</p>
      <h2 class="section-title">Keep the system legible from design decisions to shipped code.</h2>
    </div>

    <div class="two-column-copy">
      <p>
        Spectre Tokens define the source contract. Spectre UI carries that
        contract into implementation. Spectre UI Astro exposes it cleanly to
        Astro applications.
      </p>
      <p>
        Together they make the system usable in production instead of leaving
        it trapped in documentation.
      </p>
    </div>
  </section>
</Layout>
