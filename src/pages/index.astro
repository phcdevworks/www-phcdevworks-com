---
import Layout from '../layouts/Layout.astro'
import { SpCard } from '@phcdevworks/spectre-ui-astro'

const products = [
  {
    title: 'Spectre Design',
    href: '/spectre-design',
    label: 'Tokens / UI / Astro',
    copy:
      'Use the design system directly. Tokens define the contract. UI carries it. Astro ships it.',
  },
  {
    title: 'Spectre Shell',
    href: '/spectre-shell',
    label: 'Shell / Router / Signals',
    copy:
      'Build application structure on the same language instead of fragmenting layout, routing, and state.',
  },
  {
    title: 'Spectre WordPress',
    href: '/spectre-wordpress',
    label: 'WordPress / Icons',
    copy:
      'Keep CMS delivery aligned with the same product standards instead of treating it like a separate world.',
  },
]
---

<Layout
  title="Spectre"
  description="Spectre is the PHCDevworks product system built on Spectre Tokens, Spectre UI, and Spectre UI Astro."
>
  <section class="hero-atmosphere">
    <div class="hero-atmosphere__glow hero-atmosphere__glow--left"></div>
    <div class="hero-atmosphere__glow hero-atmosphere__glow--right"></div>

    <div class="home-hero home-hero--centered">
      <p class="eyebrow eyebrow--centered">The product system for PHCDevworks</p>
      <h1 class="home-headline home-headline--centered">
        Your <span>Spectre</span>
        products need
        one language.
      </h1>
      <p class="home-lead home-lead--centered">
        Spectre brings tokens, UI, Astro delivery, shell architecture, and
        WordPress support into one consistent product surface.
      </p>
      <div class="hero-links" aria-label="Primary routes">
        <a href="/spectre-design" class="hero-links__item">Spectre Design</a>
        <a href="/spectre-shell" class="hero-links__item">Spectre Shell</a>
        <a href="/spectre-wordpress" class="hero-links__item">Spectre WordPress</a>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="section-heading">
      <p class="eyebrow">Products</p>
      <h2 class="section-title">Use the products people already expect you to ship.</h2>
      <p class="section-copy">
        Start with the real Spectre products first. Keep the structure clean.
        Customize after the system is doing its job.
      </p>
    </div>

    <div class="home-product-grid">
      {
        products.map((product) => (
          <SpCard
            as="a"
            href={product.href}
            variant="outline"
            interactive
            padded
            fullHeight
            class="home-product-card"
          >
            <div class="home-product-card__stack">
              <p class="home-product-card__label">{product.label}</p>
              <h3 class="home-product-card__title">{product.title}</h3>
              <p class="home-product-card__copy">{product.copy}</p>
            </div>
          </SpCard>
        ))
      }
    </div>
  </section>

  <section class="home-section">
    <SpCard variant="elevated" padded class="home-principles-card home-principles-card--wide">
      <div class="home-principles-card__stack">
        <p class="eyebrow">Standards</p>
        <h2 class="home-panel-title">Built to use the real system.</h2>
        <p class="home-panel-copy">
          Spectre Tokens, Spectre UI, and Spectre UI Astro are the starting
          point here. The structure comes first. Then we make it ours.
        </p>
        <div class="home-principles-list" aria-label="Principles">
          <span>SSR-friendly</span>
          <span>Astro-first</span>
          <span>Token-driven</span>
          <span>Clean structure</span>
        </div>
      </div>
    </SpCard>
  </section>
</Layout>
