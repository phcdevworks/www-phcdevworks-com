---
import Layout from '../layouts/Layout.astro'
import { SpCard } from '@phcdevworks/spectre-ui-astro'

const products = [
  {
    title: 'Spectre Design',
    href: '/spectre-design',
    label: 'Tokens / UI / Astro',
    copy:
      'Use the design system directly. Tokens define the contract. UI carries it. Astro ships it.',
  },
  {
    title: 'Spectre Shell',
    href: '/spectre-shell',
    label: 'Shell / Router / Signals',
    copy:
      'Build application structure on the same language instead of fragmenting layout, routing, and state.',
  },
  {
    title: 'Spectre WordPress',
    href: '/spectre-wordpress',
    label: 'WordPress / Icons',
    copy:
      'Keep CMS delivery aligned with the same product standards instead of treating it like a separate world.',
  },
]
---

<Layout
  title="Spectre"
  description="Spectre is the PHCDevworks product system built on Spectre Tokens, Spectre UI, and Spectre UI Astro."
>
  <section class="home-hero">
    <div class="home-hero__copy">
      <p class="eyebrow">System first</p>
      <h1 class="home-headline">Spectre gives products one language.</h1>
      <p class="home-lead">
        Use the system. Customize after. Build on the parts PHCDevworks already
        ships instead of rebuilding the foundation every time.
      </p>
      <div class="home-route-list" aria-label="Primary routes">
        <a href="/spectre-design" class="home-route-list__item">
          <span>01</span>
          <span>Spectre Design</span>
        </a>
        <a href="/spectre-shell" class="home-route-list__item">
          <span>02</span>
          <span>Spectre Shell</span>
        </a>
        <a href="/spectre-wordpress" class="home-route-list__item">
          <span>03</span>
          <span>Spectre WordPress</span>
        </a>
      </div>
    </div>

    <SpCard variant="elevated" padded class="home-principles-card">
      <div class="home-principles-card__stack">
        <p class="eyebrow">Standards</p>
        <h2 class="home-panel-title">Built to use the real system.</h2>
        <p class="home-panel-copy">
          Spectre Tokens, Spectre UI, and Spectre UI Astro are the starting
          point here. The structure comes first. Then we make it ours.
        </p>
        <div class="home-principles-list" aria-label="Principles">
          <span>SSR-friendly</span>
          <span>Astro-first</span>
          <span>Token-driven</span>
          <span>Theme-aware</span>
        </div>
      </div>
    </SpCard>
  </section>

  <section class="home-section">
    <div class="section-heading">
      <p class="eyebrow">Products</p>
      <h2 class="section-title">Use the products people already expect to see.</h2>
      <p class="section-copy">
        Clean structure first. Spectre-native components first. Then the custom
        edge work comes later when the base is solid.
      </p>
    </div>

    <div class="home-product-grid">
      {
        products.map((product) => (
          <SpCard
            as="a"
            href={product.href}
            variant="outline"
            interactive
            padded
            fullHeight
            class="home-product-card"
          >
            <div class="home-product-card__stack">
              <p class="home-product-card__label">{product.label}</p>
              <h3 class="home-product-card__title">{product.title}</h3>
              <p class="home-product-card__copy">{product.copy}</p>
            </div>
          </SpCard>
        ))
      }
    </div>
  </section>

  <section class="home-section">
    <div class="section-heading">
      <p class="eyebrow">Approach</p>
      <h2 class="section-title">Standards first. Character second. Drift never.</h2>
    </div>

    <div class="home-manifesto">
      <p>Use Spectre products directly.</p>
      <p>Support light and dark cleanly.</p>
      <p>Keep the structure legible.</p>
      <p>Customize with intent after the base is right.</p>
    </div>
  </section>
</Layout>
