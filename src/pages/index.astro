---
import Layout from '../layouts/Layout.astro'
import {
  SpButton,
  SpCard,
  SpBadge,
  SpIconBox
} from '@phcdevworks/spectre-ui-astro'
---

<Layout title="Premium Software Engineering">
  <main class="hero-section">
    <div class="hero-content">
      <SpBadge variant="primary" size="lg" class="mb-6"
        >PHCDevworks Flagship</SpBadge
      >
      <h1 class="hero-title">
        The Future of <span class="gradient-text">Premium Web</span> Integration
      </h1>
      <p class="hero-subtitle">
        Scaling the Spectre Arsenal through autonomous systems and
        state-of-the-art design patterns. Built with the 8-Layer Arsenal
        paradigm.
      </p>
      <div class="cta-group">
        <SpButton
          variant="primary"
          size="lg"
          as="a"
          href="https://docs.phcdevworks.com"
        >
          Explore the Arsenal
        </SpButton>
        <SpButton variant="ghost" size="lg">Meet the Team</SpButton>
      </div>
    </div>

    <div class="features-grid">
      <SpCard variant="elevated" class="feature-card">
        <SpIconBox variant="primary" size="md">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
            ></path>
          </svg>
        </SpIconBox>
        <h3>Layer 8 Arsenal</h3>
        <p>The peak of autonomous web architecture and design systems.</p>
      </SpCard>

      <SpCard variant="elevated" class="feature-card">
        <SpIconBox variant="success" size="md">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"
            ></path>
          </svg>
        </SpIconBox>
        <h3>Edge Performance</h3>
        <p>Ultra-lite footprint with server-side excellence via Astro 5.</p>
      </SpCard>
    </div>
  </main>
</Layout>

<style>
  .hero-section {
    padding: 8rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 6rem;
  }

  .hero-content {
    max-width: 800px;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 2rem;
    letter-spacing: -0.04em;
  }

  .gradient-text {
    background: linear-gradient(135deg, #6366f1, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: #94a3b8;
    margin-bottom: 3rem;
    line-height: 1.6;
  }

  .cta-group {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    width: 100%;
  }

  .feature-card {
    padding: 2.5rem;
    text-align: left;
    background: rgba(30, 41, 59, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    transition: transform 0.3s ease;
  }

  .feature-card:hover {
    transform: translateY(-8px);
    border-color: rgba(99, 102, 241, 0.4);
  }

  .feature-card h3 {
    font-size: 1.5rem;
    margin: 1.5rem 0 1rem;
  }

  .feature-card p {
    color: #94a3b8;
    line-height: 1.6;
  }

  .mb-6 {
    margin-bottom: 1.5rem;
  }
</style>
