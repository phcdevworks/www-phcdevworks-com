---
import Layout from '../layouts/Layout.astro'
import { SpCard } from '@phcdevworks/spectre-ui-astro'

const systemAreas = [
  {
    title: 'Spectre Design',
    href: '/spectre-design',
    label: 'Tokens / UI / Astro',
    copy:
      'The core system stack for tokens, implementation, and Astro delivery.',
  },
  {
    title: 'Spectre Shell',
    href: '/spectre-shell',
    label: 'Shell / Router / Signals',
    copy:
      'The thin application shell, router, and reactive primitives for Spectre-based apps.',
  },
  {
    title: 'Spectre WordPress',
    href: '/spectre-wordpress',
    label: 'WordPress / Icons',
    copy:
      'The WordPress integration layer, including icon support and builder-aware delivery.',
  },
]
---

<Layout
  title="Spectre"
  description="Spectre is the PHCDevworks design system built on Spectre Tokens, Spectre UI, and Spectre UI Astro."
>
  <section class="hero-atmosphere">
    <div class="hero-atmosphere__glow hero-atmosphere__glow--left"></div>
    <div class="hero-atmosphere__glow hero-atmosphere__glow--right"></div>

    <div class="home-hero home-hero--centered">
      <p class="eyebrow eyebrow--centered">The PHCDevworks design system</p>
      <h1 class="home-headline home-headline--centered">
        Your design
        needs one
        <span>system.</span>
      </h1>
      <p class="home-lead home-lead--centered">
        Spectre brings tokens, implementation, Astro delivery, shell
        architecture, and WordPress support into one system language.
      </p>
      <div class="hero-links" aria-label="Primary routes">
        <a href="/spectre-design" class="hero-links__item">Spectre Design</a>
        <a href="/spectre-shell" class="hero-links__item">Spectre Shell</a>
        <a href="/spectre-wordpress" class="hero-links__item">Spectre WordPress</a>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="section-heading">
      <p class="eyebrow">System areas</p>
      <h2 class="section-title">One design system. Clear implementation layers.</h2>
      <p class="section-copy">
        Start with the real Spectre system first. Keep the structure clean. Add
        site-specific expression after the system is doing its job.
      </p>
    </div>

    <div class="home-product-grid">
      {
        systemAreas.map((area) => (
          <SpCard
            as="a"
            href={area.href}
            variant="outline"
            interactive
            padded
            fullHeight
            class="home-product-card"
          >
            <div class="home-product-card__stack">
              <p class="home-product-card__label">{area.label}</p>
              <h3 class="home-product-card__title">{area.title}</h3>
              <p class="home-product-card__copy">{area.copy}</p>
            </div>
          </SpCard>
        ))
      }
    </div>
  </section>

  <section class="home-section">
    <SpCard variant="elevated" padded class="home-principles-card home-principles-card--wide">
      <div class="home-principles-card__stack">
        <p class="eyebrow">Standards</p>
        <h2 class="home-panel-title">Built to use the real system.</h2>
        <p class="home-panel-copy">
          Spectre Tokens, Spectre UI, and Spectre UI Astro are the starting
          point. The system language comes first. Customization comes after the
          foundation is in place.
        </p>
        <div class="home-principles-list" aria-label="Principles">
          <span>SSR-friendly</span>
          <span>Astro-first</span>
          <span>Token-driven</span>
          <span>Clean structure</span>
        </div>
      </div>
    </SpCard>
  </section>
</Layout>
