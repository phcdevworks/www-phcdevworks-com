---
import Layout from '../layouts/Layout.astro'

const assets = [
  {
    name: 'Spectre WordPress',
    detail:
      'The WordPress side of Spectre for CMS-driven delivery that stays aligned with the system.',
  },
  {
    name: 'Spectre Icons',
    detail:
      'The PHCDevworks WordPress plugin for expanding native icon library support in builders through manifest-driven registration and inline SVG rendering.',
  },
]
---

<Layout
  title="Spectre WordPress"
  description="Spectre WordPress covers the WordPress side of the Spectre system, including Spectre Icons."
>
  <section class="page-intro">
    <p class="eyebrow">Spectre WordPress</p>
    <h1 class="display-headline">WordPress delivery that still speaks the same system language.</h1>
    <p class="lead page-lead">
      Spectre WordPress carries the system into CMS-driven implementation,
      including iconography and builder-aware support.
    </p>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Assets</p>
      <h2 class="section-title">CMS support without breaking the system language.</h2>
    </div>

    <div class="stack-list">
      {
        assets.map((item) => (
          <article class="stack-item">
            <p class="stack-item__kicker">Asset</p>
            <h3 class="stack-item__title">{item.name}</h3>
            <p class="stack-item__copy">{item.detail}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section-block section-band">
    <div class="section-heading">
      <p class="eyebrow">Use case</p>
      <h2 class="section-title">Keep content platforms aligned with the same visual and technical standards.</h2>
    </div>

    <div class="two-column-copy">
      <p>
        This side of Spectre is for teams shipping on WordPress without
        accepting visual drift, icon inconsistency, or disconnected interface
        decisions.
      </p>
      <p>
        It keeps the system recognizable across content-heavy environments while
        staying grounded in the same implementation logic as the rest of
        Spectre.
      </p>
    </div>
  </section>
</Layout>
