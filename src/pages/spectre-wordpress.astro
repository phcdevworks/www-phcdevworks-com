---
import Layout from '../layouts/Layout.astro'
import { SpCard, SpButton } from '@phcdevworks/spectre-ui-astro'

const assets = [
  {
    name: 'Spectre WordPress',
    detail:
      'The WordPress side of Spectre for CMS-driven delivery that stays aligned with the system tokens and visual language.',
  },
  {
    name: 'Spectre Icons',
    detail:
      'The PHCDevworks WordPress plugin for expanding native icon library support in builders through manifest-driven registration and inline SVG rendering.',
  },
]
---

<Layout
  title="Spectre WordPress"
  description="Spectre WordPress covers the WordPress side of the Spectre system, including Spectre Icons."
>
  <section class="page-intro">
    <p class="eyebrow">Spectre WordPress</p>
    <h1 class="display-headline">WordPress delivery that still speaks the <span>same system language.</span></h1>
    <p class="lead page-lead">
      Spectre WordPress covers CMS-driven delivery and icon support without
      drifting away from the core system.
    </p>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Assets</p>
      <h2 class="section-title">CMS support without breaking the system language.</h2>
      <p class="section-copy">
        Two assets that keep WordPress-based projects in the same visual contract
        as the rest of the Spectre system.
      </p>
    </div>

    <div class="stack-list stack-list--cols-2">
      {
        assets.map((item) => (
          <SpCard as="article" variant="outline" padded fullHeight class="stack-card">
            <div class="home-product-card__stack">
              <p class="stack-item__kicker">Asset</p>
              <h3 class="stack-item__title">{item.name}</h3>
              <p class="stack-item__copy">{item.detail}</p>
            </div>
          </SpCard>
        ))
      }
    </div>
  </section>

  <section class="section-block section-band">
    <div class="section-heading">
      <p class="eyebrow">Use case</p>
      <h2 class="section-title">Keep content platforms aligned with the same visual and technical standards.</h2>
    </div>

    <div class="two-column-copy">
      <p>
        Spectre WordPress keeps content-heavy environments aligned with the
        same system language used elsewhere in Spectre.
      </p>
      <p>
        That includes icons, builder integration, and WordPress-specific
        delivery work that still honors the shared contract.
      </p>
    </div>
  </section>

  <section class="home-section">
    <SpCard variant="elevated" padded class="home-principles-card home-principles-card--wide">
      <div class="home-principles-card__stack">
        <p class="eyebrow">PHCDevworks</p>
        <h2 class="home-panel-title">The same contract, delivered in WordPress.</h2>
        <p class="home-panel-copy">
          Spectre WordPress keeps CMS delivery aligned with the same system
          language used everywhere else in Spectre. No drift, no exceptions.
        </p>
        <div class="page-cta-links">
          <SpButton as="a" href="/" variant="ghost">View the full system</SpButton>
        </div>
      </div>
    </SpCard>
  </section>
</Layout>
