---
import Layout from '../layouts/Layout.astro'
import { SpCard, SpButton } from '@phcdevworks/spectre-ui-astro'

const modules = [
  {
    name: 'Spectre Shell',
    detail:
      'The thin application shell for Spectre apps. Handles startup, frame structure, and the top-level application boundary.',
  },
  {
    name: 'Spectre Shell Router',
    detail:
      'The routing layer that registers application routes and handles shell movement between views.',
  },
  {
    name: 'Spectre Shell Signals',
    detail:
      'The reactive primitives layer for local UI state inside Spectre shells.',
  },
]
---

<Layout
  title="Spectre Shell"
  description="Spectre Shell covers Spectre Shell, Spectre Shell Router, and Spectre Shell Signals as the application-shell side of the Spectre system."
>
  <section class="page-intro">
    <p class="eyebrow">Spectre Shell</p>
    <h1 class="display-headline">Application structure without <span>framework noise.</span></h1>
    <p class="lead page-lead">
      Spectre Shell covers the application frame, routing, and reactive
      primitives for Spectre-based apps.
    </p>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Modules</p>
      <h2 class="section-title">Shell, routing, and state built as one application layer.</h2>
      <p class="section-copy">
        Three focused modules that solve the application edges without growing into a framework.
      </p>
    </div>

    <div class="stack-list stack-list--cols-3">
      {
        modules.map((item) => (
          <SpCard as="article" variant="outline" padded fullHeight class="stack-card">
            <div class="home-product-card__stack">
              <p class="stack-item__kicker">Module</p>
              <h3 class="stack-item__title">{item.name}</h3>
              <p class="stack-item__copy">{item.detail}</p>
            </div>
          </SpCard>
        ))
      }
    </div>
  </section>

  <section class="section-block section-band">
    <div class="section-heading">
      <p class="eyebrow">Operating model</p>
      <h2 class="section-title">Keep the frame thin and the structure explicit.</h2>
    </div>

    <div class="two-column-copy">
      <p>
        Spectre Shell exists to solve the application edges: startup, route
        structure, and local state around the interface.
      </p>
      <p>
        That keeps the shell useful, predictable, and small enough to stay out
        of the way.
      </p>
    </div>
  </section>

  <section class="home-section">
    <SpCard variant="elevated" padded class="home-principles-card home-principles-card--wide">
      <div class="home-principles-card__stack">
        <p class="eyebrow">PHCDevworks</p>
        <h2 class="home-panel-title">The shell stays thin by design.</h2>
        <p class="home-panel-copy">
          Spectre Shell handles the edges so your application logic doesn't have to.
          Route management, frame structure, and reactive state — tight and predictable.
        </p>
        <div class="page-cta-links">
          <SpButton as="a" href="/" variant="ghost">View the full system</SpButton>
        </div>
      </div>
    </SpCard>
  </section>
</Layout>
