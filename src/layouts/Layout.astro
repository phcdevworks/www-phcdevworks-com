---
import { ClientRouter } from 'astro:transitions'
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const {
  title,
  description = 'PHCDevworks builds design systems, application foundations, and technical infrastructure.',
} = Astro.props
const pathname = Astro.url.pathname

const navItems = [
  { href: '/', label: 'PHCDevworks' },
  { href: '/spectre-design', label: 'Spectre Design' },
  { href: '/spectre-shell', label: 'Spectre Shell' },
  { href: '/spectre-wordpress', label: 'Spectre WordPress' },
]
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | PHCDevworks</title>
    <meta name="description" content={description} />
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="site-body antialiased min-h-screen">
    <div class="site-frame">
      <header class="site-header">
        <div class="site-header__inner">
          <a href="/" class="site-mark" aria-label="PHCDevworks home">
            <span class="site-mark__eyebrow">Spectre Design System</span>
            <span class="site-mark__title">PHCDevworks</span>
          </a>

          <nav class="site-nav" aria-label="Primary">
            {
              navItems.map((item) => {
                const isActive =
                  item.href === '/'
                    ? pathname === '/'
                    : pathname.startsWith(item.href)

                return (
                  <a
                    href={item.href}
                    class:list={[
                      'site-nav__link',
                      isActive && 'site-nav__link--active',
                    ]}
                  >
                    {item.label}
                  </a>
                )
              })
            }
          </nav>
        </div>
      </header>

      <main class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__inner">
          <div>
            <p class="site-footer__label">Spectre design system</p>
            <p class="site-footer__copy">
              Tokens, implementation, Astro delivery, shell architecture, and
              WordPress support under PHCDevworks.
            </p>
          </div>

          <p class="site-footer__meta">
            PHCDevworks &copy; {new Date().getFullYear()}
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
