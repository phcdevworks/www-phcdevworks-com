---
import { ClientRouter } from 'astro:transitions'
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'The official PHCDevworks flagship website.' } =
  Astro.props
const pathname = Astro.url.pathname

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/spectre-design', label: 'Spectre Design' },
  { href: '/spectre-shell', label: 'Spectre Shell' },
  { href: '/spectre-wordpress', label: 'Spectre WordPress' },
]
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | PHCDevworks</title>
    <meta name="description" content={description} />
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="sp-theme--dark antialiased min-h-screen">
    <div class="site-frame">
      <header class="site-header">
        <div class="site-header__inner">
          <a href="/" class="site-mark" aria-label="Spectre home">
            <span class="site-mark__eyebrow">PHCDevworks Product System</span>
            <span class="site-mark__title">Spectre</span>
          </a>

          <nav class="site-nav" aria-label="Primary">
            {
              navItems.map((item) => {
                const isActive =
                  item.href === '/'
                    ? pathname === '/'
                    : pathname.startsWith(item.href)

                return (
                  <a
                    href={item.href}
                    class:list={[
                      'site-nav__link',
                      isActive && 'site-nav__link--active',
                    ]}
                  >
                    {item.label}
                  </a>
                )
              })
            }
          </nav>
        </div>
      </header>

      <main class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__inner">
          <div class="site-footer__intro">
            <p class="site-footer__label">PHCDevworks</p>
            <p class="site-footer__title">Systems, products, and platform work.</p>
            <p class="site-footer__copy">
              The PHCDevworks flagship site. Built to present the company, the
              Spectre ecosystem, and the technical work behind it with
              structure instead of filler.
            </p>
          </div>

          <div class="site-footer__aside">
            <nav class="site-footer__nav" aria-label="Footer">
              <a href="/" class="site-footer__link">Home</a>
              <a href="/spectre-design" class="site-footer__link">
                Spectre Design
              </a>
              <a href="/spectre-shell" class="site-footer__link">
                Spectre Shell
              </a>
              <a href="/spectre-wordpress" class="site-footer__link">
                Spectre WordPress
              </a>
              <a
                href="https://github.com/phcdevworks"
                class="site-footer__link"
                target="_blank"
                rel="noreferrer"
              >
                GitHub
              </a>
            </nav>

            <p class="site-footer__meta">
              PHCDevworks &copy; {new Date().getFullYear()}
            </p>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
