---
import { ClientRouter } from 'astro:transitions'
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'The official PHCDevworks flagship website.' } =
  Astro.props
const pathname = Astro.url.pathname

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/spectre-design', label: 'Spectre Design' },
  { href: '/spectre-shell', label: 'Spectre Shell' },
  { href: '/spectre-wordpress', label: 'Spectre WordPress' },
]
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | PHCDevworks</title>
    <meta name="description" content={description} />
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="sp-theme--dark antialiased min-h-screen">
    <div class="site-frame">
      <header class="site-header">
        <div class="site-header__inner">
          <a href="/" class="site-mark" aria-label="Spectre home">
            <span class="site-mark__eyebrow">PHCDevworks Product System</span>
            <span class="site-mark__title">Spectre</span>
          </a>

          <nav class="site-nav" aria-label="Primary">
            {
              navItems.map((item) => {
                const isActive =
                  item.href === '/'
                    ? pathname === '/'
                    : pathname.startsWith(item.href)

                return (
                  <a
                    href={item.href}
                    class:list={[
                      'site-nav__link',
                      isActive && 'site-nav__link--active',
                    ]}
                  >
                    {item.label}
                  </a>
                )
              })
            }
          </nav>
        </div>
      </header>

      <main class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__inner site-footer__inner--premium">
          <p class="site-footer__meta site-footer__meta--premium">
            PHCDevworks &copy; {new Date().getFullYear()}.
            <span class="site-footer__meta-copy">
              Design systems, UI tooling, and developer infrastructure.
            </span>
          </p>

          <div class="site-footer__rail" aria-label="Footer links">
            <a href="/" class="site-footer__route">Home</a>
            <a href="/spectre-design" class="site-footer__route">
              Spectre Design
            </a>
            <a href="/spectre-shell" class="site-footer__route">
              Spectre Shell
            </a>
            <a href="/spectre-wordpress" class="site-footer__route">
              Spectre WordPress
            </a>
            <a
              href="https://github.com/phcdevworks"
              class="site-footer__icon-link"
              target="_blank"
              rel="noreferrer"
            >
              <span class="sr-only">GitHub</span>
              <svg
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
                class="size-5"
              >
                <path
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                  clip-rule="evenodd"
                  fill-rule="evenodd"
                />
              </svg>
            </a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
