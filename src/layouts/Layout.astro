---
import { ClientRouter } from 'astro:transitions'
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const {
  title,
  description = 'PHCDevworks builds systems, products, and technical foundations.',
} = Astro.props
const pathname = Astro.url.pathname

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/spectre-design', label: 'Spectre Design' },
  { href: '/spectre-shell', label: 'Spectre Shell' },
  { href: '/spectre-wordpress', label: 'Spectre WordPress' },
]
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | PHCDevworks</title>
    <meta name="description" content={description} />
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="site-body antialiased min-h-screen">
    <script is:inline>
      const storedTheme = localStorage.getItem('phc-theme')
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
      const theme = storedTheme ?? (prefersDark ? 'dark' : 'light')
      if (theme === 'dark') {
        document.documentElement.dataset.spectreTheme = 'dark'
      } else {
        delete document.documentElement.dataset.spectreTheme
      }
      document.body.dataset.theme = theme
    </script>

    <div class="site-frame">
      <header class="site-header">
        <div class="site-header__inner">
          <a href="/" class="site-mark" aria-label="Spectre home">
            <span class="site-mark__eyebrow">PHCDevworks Product System</span>
            <span class="site-mark__title">Spectre</span>
          </a>

          <nav class="site-nav" aria-label="Primary">
            {
              navItems.map((item) => {
                const isActive =
                  item.href === '/'
                    ? pathname === '/'
                    : pathname.startsWith(item.href)

                return (
                  <a
                    href={item.href}
                    class:list={[
                      'site-nav__link',
                      isActive && 'site-nav__link--active',
                    ]}
                  >
                    {item.label}
                  </a>
                )
              })
            }
          </nav>

          <div class="theme-switch" aria-label="Theme">
            <button class="theme-switch__link" type="button" data-theme-choice="light">
              Light
            </button>
            <span class="theme-switch__divider">/</span>
            <button class="theme-switch__link" type="button" data-theme-choice="dark">
              Dark
            </button>
          </div>
        </div>
      </header>

      <main class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__inner">
          <div>
            <p class="site-footer__label">Spectre ecosystem</p>
            <p class="site-footer__copy">
              Tokens, UI, Astro delivery, shell architecture, and WordPress
              support under the PHCDevworks umbrella.
            </p>
          </div>

          <p class="site-footer__meta">
            PHCDevworks &copy; {new Date().getFullYear()}
          </p>
        </div>
      </footer>
    </div>

    <script is:inline>
      const applyTheme = (theme) => {
        if (theme === 'dark') {
          document.documentElement.dataset.spectreTheme = 'dark'
        } else {
          delete document.documentElement.dataset.spectreTheme
        }
        document.body.dataset.theme = theme
        localStorage.setItem('phc-theme', theme)
      }

      document.querySelectorAll('[data-theme-choice]').forEach((node) => {
        node.addEventListener('click', () => {
          applyTheme(node.getAttribute('data-theme-choice'))
        })
      })
    </script>
  </body>
</html>
